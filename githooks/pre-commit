#!/usr/bin/env bash
# Auto-format staged C++ files before committing, so formatting is never an issue.
# Install with: ./format.sh install-hooks   (sets core.hooksPath to this directory)
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
CLANG_FORMAT="${CLANG_FORMAT:-clang-format}"

if ! command -v "$CLANG_FORMAT" >/dev/null 2>&1; then
    echo "pre-commit: '$CLANG_FORMAT' not found; skipping format check." >&2
    exit 0
fi

# Staged C++ files, applying the same exclusions as format.sh / CI.
mapfile -t files < <(
    git diff --cached --name-only --diff-filter=ACMR \
        -- '*.cpp' '*.hpp' '*.cc' \
        | grep -Ev '(^|/)(linenoise-ng/|kiln/inner/|tests/integration/)' || true
)

[[ ${#files[@]} -eq 0 ]] && exit 0

formatted=()
for f in "${files[@]}"; do
    [[ -f "$repo_root/$f" ]] || continue
    "$CLANG_FORMAT" -i "$repo_root/$f"
    # Re-stage if formatting changed the file.
    if ! git diff --quiet -- "$f"; then
        git add -- "$f"
        formatted+=("$f")
    fi
done

if [[ ${#formatted[@]} -gt 0 ]]; then
    echo "pre-commit: reformatted and re-staged ${#formatted[@]} file(s):"
    printf '  %s\n' "${formatted[@]}"
fi
